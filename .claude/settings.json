{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(ls *)",
      "Bash(cd backend && npm run build)",
      "Bash(cd backend && npm run dev)",
      "Bash(cd backend && npm run start)",
      "Bash(cd backend && npm install*)",
      "Bash(cd website && npm run build)",
      "Bash(cd website && npm run lint)",
      "Bash(cd website && npm run dev)",
      "Bash(cd website && npm run start)",
      "Bash(cd website && npm install*)",
      "Bash(curl *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git status *)",
      "Bash(git branch *)",
      "Bash(psql *)",
      "Bash(gitleaks *)",
      "Bash(gh *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(pnpm test:run *)",
      "Bash(pnpm check *)",
      "Bash(pnpm test:e2e *)",
      "Bash(npm run build*)"
    ]
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/destructive-git.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/secret-scan.sh"
          },
          {
            "type": "command",
            "command": "if echo \"$TOOL_INPUT\" | grep -qE '\"command\"\\s*:\\s*\"(git commit|git push)'; then cd backend && npm run build --silent 2>&1 | tail -5; BUILD_EXIT=$?; if [ $BUILD_EXIT -ne 0 ]; then echo '⚠️  Backend build failed — fix TypeScript errors before committing'; exit 1; fi; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "file_path=$(echo \"$TOOL_INPUT\" | grep -o '\"file_path\"\\s*:\\s*\"[^\"]*\"' | head -1 | sed 's/.*\"\\([^\"]*\\)\"$/\\1/'); if echo \"$file_path\" | grep -q 'backend/src/.*\\.ts$'; then missing=$(grep -n \"from '\\.\\.\\?/\" \"$file_path\" 2>/dev/null | grep -v \"\\.js'\" | grep -v \"node:\" | head -5); if [ -n \"$missing\" ]; then echo \"⚠️  Missing .js extension on local imports in $file_path:\"; echo \"$missing\"; echo \"All local imports in the backend MUST end with .js (ESM requirement)\"; exit 1; fi; fi"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/format.sh"
          },
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/circular-deps.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/token-telemetry.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-context.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/reload-spokes.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "executor",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/change-budget.sh"
          }
        ]
      }
    ]
  }
}
