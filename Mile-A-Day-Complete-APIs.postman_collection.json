{
	"info": {
		"name": "Mile-A-Day Complete API",
		"description": "Complete collection for all Mile-A-Day endpoints",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{authToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Sign In",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user_id\": \"apple_user_123\",\n  \"identity_token\": \"eyJraWQiOiJXNldjT0tCIiwiYWxnIjoiUlMyNTYifQ...\",\n  \"authorization_code\": \"code123\",\n  \"email\": \"user@example.com\",\n  \"device_info\": {\n    \"model\": \"iPhone\",\n    \"os_version\": \"iOS 18.0\"\n  }\n}"
						},
						"url": {
							"raw": "{{domain}}/auth/signin",
							"host": [
								"{{domain}}"
							],
							"path": [
								"auth",
								"signin"
							]
						},
						"description": "Sign in with Apple. Returns user object, accessToken (30 day expiry), refreshToken (long-lived), expiresIn ('30d'), and expiresAt (Unix timestamp in milliseconds). Device info is stored for session tracking."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"your_refresh_token_here\"\n}"
						},
						"url": {
							"raw": "{{domain}}/auth/refresh",
							"host": [
								"{{domain}}"
							],
							"path": [
								"auth",
								"refresh"
							]
						},
						"description": "Exchange a refresh token for a new access token and refresh token pair. The old refresh token is revoked (token rotation). Returns new accessToken (30 day expiry), refreshToken, expiresIn ('30d'), and expiresAt (Unix timestamp in milliseconds)."
					},
					"response": []
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"refreshToken\": \"your_refresh_token_here\"\n}"
						},
						"url": {
							"raw": "{{domain}}/auth/logout",
							"host": [
								"{{domain}}"
							],
							"path": [
								"auth",
								"logout"
							]
						},
						"description": "Revoke a single refresh token (logout from this session only). Other sessions remain active. Requires authentication."
					},
					"response": []
				},
				{
					"name": "Logout All",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{domain}}/auth/logout-all",
							"host": [
								"{{domain}}"
							],
							"path": [
								"auth",
								"logout-all"
							]
						},
						"description": "Revoke all refresh tokens for the authenticated user (logout from all sessions). Requires authentication."
					},
					"response": []
				}
			],
			"description": "Authentication endpoints"
		},
